{
  "mcpServers": {
    "minigame-assets": {
      "command": "node",
      "args": ["/absolute/path/to/minigame-assets-mcp/dist/index.js"],
      "env": {
        "OPENAI_API_KEY": "sk-...",
        "GEMINI_API_KEY": "AIza...",
        "ASSETS_OUTPUT_DIR": "./generated-assets",
        "TRANSPORT": "stdio"
      }
    }
  }
}
