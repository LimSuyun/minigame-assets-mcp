# OpenAI API Key — 이미지(gpt-image-1), 영상(Sora) 사용 시 필수
OPENAI_API_KEY=sk-...

# Google Gemini API Key — 이미지(Imagen 4), 영상(Veo) 사용 시 필수
GEMINI_API_KEY=AIza...

# 에셋 저장 경로 (기본: ./generated-assets)
ASSETS_OUTPUT_DIR=./generated-assets

# 게임 컨셉 파일 경로 (기본값 있음)
CONCEPT_FILE=./game-concept.json
CONCEPT_MD_FILE=./CONCEPT.md

# 로컬 음악 서버 URL (AudioCraft/MusicGen 사용 시)
LOCAL_MUSIC_SERVER_URL=http://localhost:7860
