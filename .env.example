# OpenAI API Key — 이미지(gpt-image-2/1.5/1/mini), 프롬프트 리파인(GPT-5.4-nano), 영상(Sora)
OPENAI_API_KEY=sk-...

# 마스터 에셋 저장 경로 (기본: ./.minigame-assets — 원본 고해상도, .gitignore 권장)
ASSETS_OUTPUT_DIR=./.minigame-assets

# 설계 문서 경로 — 모두 .minigame-assets/ 하위에 모임
CONCEPT_FILE=./.minigame-assets/game-concept.json
CONCEPT_MD_FILE=./.minigame-assets/CONCEPT.md
GAME_DESIGN_FILE=./.minigame-assets/GAME_DESIGN.json
ASSET_SIZE_SPEC_FILE=./.minigame-assets/asset_size_spec.json

# 로컬 음악 서버 URL (AudioCraft/MusicGen 사용 시)
LOCAL_MUSIC_SERVER_URL=http://localhost:7860
