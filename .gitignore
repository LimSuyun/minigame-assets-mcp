# Dependencies
node_modules/

# Build output
dist/

# Environment variables (API keys — NEVER commit)
.env
.env.local
.env.*.local

# MCP config with real API keys (use .mcp.json.example instead)
.mcp.json
# Exception: the plugin distribution config has no secrets (just `npx -y minigame-assets-mcp`)
!plugins/**/.mcp.json

# Local Claude settings (contains local paths and permissions)
.claude/settings.local.json

# Generated assets
generated-assets/
test-output/
output/

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
Thumbs.db

# Local process/notes documentation (not for public repo)
PROCESS.md
MCP_PLAN.md
docs/archive/

# Logs
*.log
npm-debug.log*

# TypeScript incremental build
*.tsbuildinfo

# 로컬 전용 스크립트 (개인 콘텐츠·일회성 디버그 — 커밋/npm publish 모두 제외)
scripts/.local/
