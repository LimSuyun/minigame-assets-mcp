{
  "name": "minigame-assets-mcp",
  "version": "1.0.0",
  "description": "MCP server for generating game assets using AI (images, sprites, weapons, backgrounds, logos, thumbnails, music, video)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "minigame-assets-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    ".env.example",
    ".mcp.json.example"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "game-assets",
    "ai",
    "openai",
    "gemini",
    "sprite",
    "image-generation",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/form-data": "^2.2.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
